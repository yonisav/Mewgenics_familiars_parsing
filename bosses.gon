        move DefaultMove
        attack BasicBigMelee
        
        spells [
            SimonSays_Scatter
            SimonSays_ComeHere
            SimonSays_GoAway
            //TODO: SimonSays_Spread (each cat has a 2-3 radius danger region surrounding it, spread them out to not get hit)

            Simon_Tentacle
            Simon_Trash
            Simon_Shot
        ]
    }

    passives {
        BonusTurnPattern [ 
            {
                dispersed_bonus_turns 2
                round_end_bonus_turns 1
            }

            {
                round_end_bonus_turns 1
                takes_main_turn false
            }
        ]

        Trample 3
        TransformOnDeath SimonFlopper
    }
    
    ai {
        brain PatternBrain
        decision_weights default
        move_weights keep_distance_always_move
        stun_advances_pattern true
        auto_orient false
        
        mainturn_pattern {
            do_priority [attack Simon_Shot]
        }

        dispersed_bonusturn_pattern {
            do Simon_Trash
            do Simon_Tentacle
        }
        
        round_end_bonusturn_pattern {
            do_random [SimonSays_Scatter, SimonSays_ComeHere, SimonSays_GoAway]
            do_nothing []
        }
    }
}

SimonFlopper {
    graphics {
        movieclip SimonFlop
        name "ENEMY_THROBBINGKING_NAME"
        shadow_size 2
    }

    stats {
        strength 5
        dexterity 5
        constitution 5
        intelligence 5
        speed 5
        charisma 5
    }
    
    properties {
        tag blob
        faction enemies
        type boss
        movement 5
        mana_regen 999
        mana 100
        dispersed_bonus_turns 3
        
        health 250

        size 2x2
        move_block everything_even_when_dead
    }

    abilities {
        move DefaultMove
        attack BasicBigMelee
        
        spells [
            SimonFlopper_WiggleFake
            SimonFlopper_WiggleChance
            SimonFlopper_WiggleGuaranteed
            SimonFlopper_Tentacle
            SimonFlopper_SpawnMinion
        ]
    }

    passives {
        FormChanger {
            Flop { //initial flopped down state, the state you start in when the king goes to his second form. takex exactly 4 wiggles to get up
                animation_suffix "Down"

                ai {
                    brain PatternBrain
                    decision_weights default
                    move_weights keep_distance_always_move
                    auto_orient false
                    reset_pattern_on_formswitch true

                    pattern {
                        do **SimonFlopper_WiggleFake
                        do **SimonFlopper_WiggleFake
                        do **SimonFlopper_WiggleFake
                        do **SimonFlopper_WiggleGuaranteed
                    }
                }
                passives {
                    BackstabAllDirections 1
                }
            }
            Flop2 { //subsequent flopped down state, when hit he has a chance to go into this state, takes 2 to 6 wiggles to get up
                animation_suffix "Down"

                ai {
                    brain PatternBrain
                    decision_weights default
                    move_weights keep_distance_always_move
                    auto_orient false
                    reset_pattern_on_formswitch true

                    pattern {
                        do **SimonFlopper_WiggleFake
                        do **SimonFlopper_WiggleChance
                        do **SimonFlopper_WiggleChance
                        do **SimonFlopper_WiggleChance
                        do **SimonFlopper_WiggleChance
                        do **SimonFlopper_WiggleGuaranteed
                    }
                }
                passives {
                    BackstabAllDirections 1
                }
            }
            Normal {
                animation_suffix "Up"

                ai {
                    brain PatternBrain
                    decision_weights default
                    move_weights keep_distance_always_move
                    auto_orient false

                    pattern {
                        do SimonFlopper_Tentacle
                        move_then_do SimonFlopper_SpawnMinion
                    }
                    fallback {
                        do attack
                    }
                }
                passives {
                    ChanceToFormChangeOnAbilityDamage {
                        chance 15%
                        form Flop2
                    }
                }
            }

            initial_form Flop
        }

        Trample 3
    }
    
    ai {
        brain GenericBrain
        decision_weights default
        move_weights keep_distance_always_move
        auto_orient false
    }
}

