BomberRat {
    graphics {
        movieclip BomberRat
        name "ENEMY_RADICALRAT_NAME"
        projectile_spawn_offset [.25 1]
		tooltip "ENEMY_RADICALRAT_DESC"
    }

    stats {
        strength  5
        dexterity 5
        constitution 5
        intelligence 5
        speed 5
        charisma 5
    }
    
    properties {
        tag rat
        faction enemies
        type boss

        mana_regen 999
        mana 100
        initiative -100
        movement 5
        health 67
        
        dispersed_bonus_turns 2
        dispersed_bonus_turns_consider_initiative false
        dispersed_bonus_turns_before_cats true
        last_turn_is_main_turn true
    }

    abilities {
        move DefaultMove
        attack None
        
        spells [
            SpawnBomb
            BombRatTurtle
            RockToss_BomberRat
        ]
    }

    passives {
        FormChanger {
            Default { 
            }
            Rain {
                ai {
                    brain PatternBrain

                    pattern {
                        do_priority [*RockToss_BomberRat, RockToss_BomberRat]
                    }

                    decision_weights extra_careless
                    move_weights keep_distance_always_move
                }
            }

            initial_form Default
        }

        FormChangeDuringWeatherElement {
            element Water
            form Rain
        }

        BossRewards {
            common RatBomb
            rare RadGlasses
        }
    }
    
    ai {
        brain PatternBrain
        decision_weights extra_careless
        move_weights chaotic_runaway

        mainturn_pattern {
            do **BombRatTurtle
        }
        
        bonusturn_pattern {
            do *SpawnBomb
        }
        
        fallback_advances_pattern true
        stun_advances_pattern false
    }
}

